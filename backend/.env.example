# MongoDB Connection URI - Get from MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# Server Port (Render will override with process.env.PORT automatically)
PORT=5000

# JWT Secret for token authentication - Use a strong random string (min 32 chars)
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters

# Frontend URL for CORS - Use your deployed frontend URL on Render
# Local Dev: http://localhost:5173
# Production: https://your-frontend-domain.onrender.com
FRONTEND_URL=https://trustcurrency-1.onrender.com

# Environment (Optional - helps with logging)
NODE_ENV=production
FRONTEND_URL=https://trustcurrency-1.onrender.com
FRONTEND_URL=http://localhost:5173
